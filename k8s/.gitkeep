### --- Terraform (Crucial!) --- ###
# Local build folder
.terraform/
# State files - contains SENSITIVE database passwords and secrets in plain text
*.tfstate
*.tfstate.backup
# Variables files (where you might put secrets locally)
*.tfvars
*.tfvars.json
# Lock file
.terraform.lock.hcl
# Crash logs
crash.log

